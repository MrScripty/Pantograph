{
  "name": "Pantograph",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "24.12.0",
    "npm": "11.6.2"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:desktop": "tauri dev",
    "build:desktop": "tauri build",
    "lint": "eslint scripts eslint.config.mjs vite.config.ts --max-warnings 0",
    "lint:full": "eslint src packages scripts eslint.config.mjs vite.config.ts --max-warnings 0",
    "lint:critical": "node scripts/check-critical-antipatterns.mjs",
    "lint:a11y": "node scripts/check-svelte-a11y.mjs",
    "lint:no-new": "npm run lint:critical && npm run lint:a11y && npm run traceability",
    "format:check": "cargo fmt --all -- --check",
    "test:frontend": "node --experimental-strip-types --test src/components/edgeInsertInteraction.test.ts src/components/workflowConnections.test.ts src/components/workflowContainerBoundary.test.ts src/components/workflowContainerSelection.test.ts src/components/workflowGraphSource.test.ts src/components/workflowMiniMap.test.ts src/components/workflowPaletteDrag.test.ts src/components/workflowGraphSync.test.ts src/components/workflowToolbarEvents.test.ts src/components/diagnostics/presenters.test.ts src/components/nodes/workflow/audioOutputState.test.ts src/components/nodes/workflow/dependencyEnvironmentState.test.ts src/components/nodes/workflow/expandSettingsDisplay.test.ts src/components/nodes/workflow/primitiveInputMetadata.test.ts src/lib/workflowGraphMutationResponse.test.ts src/stores/diagnosticsProjection.test.ts packages/svelte-graph/src/workflowConnections.test.ts packages/svelte-graph/src/workflowGraphSync.test.ts packages/svelte-graph/src/workflowHorseshoeKeyboard.test.ts packages/svelte-graph/src/workflowMiniMap.test.ts packages/svelte-graph/src/workflowNodeActivation.test.ts packages/svelte-graph/src/stores/runtimeData.test.ts packages/svelte-graph/src/stores/definitionOverlay.test.ts packages/svelte-graph/src/stores/createSessionStores.test.ts packages/svelte-graph/src/stores/createWorkflowStores.test.ts packages/svelte-graph/src/stores/workflowExecutionEvents.test.ts packages/svelte-graph/src/stores/workflowGraphMutationResponse.test.ts packages/svelte-graph/src/workflowEventOwnership.test.ts packages/svelte-graph/src/portTypeCompatibility.test.ts packages/svelte-graph/src/workflowSelection.test.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "test": "cargo test -p node-engine --lib && cargo test -p workflow-nodes --lib",
    "traceability": "./scripts/check-decision-traceability.sh",
    "test:runtime-separation": "./scripts/check-no-python-linkage.sh",
    "release:sbom": "./scripts/generate-release-sbom.sh",
    "check": "npm run lint && npm run lint:critical && npm run typecheck && npm run test",
    "hooks:install": "npx lefthook install"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tiptap/core": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@xyflow/svelte": "^1.5.0",
    "lucide-svelte": "^0.562.0",
    "svelte": "^5.0.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^22.14.0",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.19",
    "es-module-lexer": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.0"
  }
}
