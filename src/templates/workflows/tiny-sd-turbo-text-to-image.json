{
  "name": "Tiny SD Turbo Text to Image",
  "description": "Minimal text-to-image workflow that routes an imported tiny-sd-turbo model from Puma-Lib through dependency preflight into diffusion inference.",
  "version": "1.0.0",
  "orchestration": {
    "id": "tiny-sd-turbo-text-to-image-orch",
    "name": "Tiny SD Turbo Text to Image",
    "description": "Single data-graph orchestration for local tiny-sd-turbo text-to-image generation.",
    "nodes": [
      {
        "id": "start",
        "nodeType": "start",
        "position": [80, 180],
        "config": {}
      },
      {
        "id": "generate-image",
        "nodeType": "data_graph",
        "position": [260, 180],
        "config": {
          "dataGraphId": "tiny-sd-turbo-generate",
          "inputMappings": {},
          "outputMappings": {}
        }
      },
      {
        "id": "end",
        "nodeType": "end",
        "position": [460, 180],
        "config": {}
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "start",
        "sourceHandle": "next",
        "target": "generate-image",
        "targetHandle": "input"
      },
      {
        "id": "e2",
        "source": "generate-image",
        "sourceHandle": "next",
        "target": "end",
        "targetHandle": "input"
      }
    ],
    "dataGraphs": {
      "generate-image": "tiny-sd-turbo-generate"
    }
  },
  "dataGraphs": {
