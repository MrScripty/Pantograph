          "source_handle": "value",
          "target": "diffusion",
          "target_handle": "cfg_scale"
        },
        {
          "id": "e10",
          "source": "seed",
          "source_handle": "value",
          "target": "diffusion",
          "target_handle": "seed"
        },
        {
          "id": "e11",
          "source": "width",
          "source_handle": "value",
          "target": "diffusion",
          "target_handle": "width"
        },
        {
          "id": "e12",
          "source": "height",
          "source_handle": "value",
          "target": "diffusion",
          "target_handle": "height"
        },
        {
          "id": "e13",
