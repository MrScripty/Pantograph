            "label": "Prompt",
            "text": "paper lantern in the rain, cinematic lighting, detailed illustration"
          }
        },
        {
          "id": "negative-prompt",
          "node_type": "text-input",
          "position": { "x": 80, "y": 310 },
          "data": {
            "label": "Negative Prompt",
            "text": "blurry, low quality, distorted"
          }
        },
        {
          "id": "steps",
          "node_type": "number-input",
          "position": { "x": 80, "y": 500 },
          "data": {
            "label": "Steps",
            "value": 4
          }
        },
        {
          "id": "cfg-scale",
          "node_type": "number-input",
          "position": { "x": 260, "y": 500 },
          "data": {
            "label": "CFG Scale",
            "value": 0
          }
        },
        {
          "id": "seed",
          "node_type": "number-input",
          "position": { "x": 440, "y": 500 },
          "data": {
            "label": "Seed",
            "value": 42
          }
